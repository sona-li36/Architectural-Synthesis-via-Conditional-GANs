# Project environment variables
# Customize these values for your local setup.

# Data paths
DATA_DIR=data
DATASET_DIR=data/dataset
RAW_DATA_DIR=data/raw_mixed
OUTPUT_DIR=outputs
CHECKPOINT_DIR=checkpoints
MODEL_DIR=models

# Training / inference settings
BATCH_SIZE=8
LEARNING_RATE=0.0001
NUM_WORKERS=4

# Python / caching
PYTHONPATH=.
TRANSFORMERS_CACHE=.cache/transformers
HF_HOME=.cache/huggingface
TOKENS_PARALLELISM=false

# Optional flags
DEBUG=false
